#!/usr/bin/env python3
"""Watch GZ302 控制中心 as an independent keyboard key; launch aipc-voice-once.

InputPlumber still owns Asus WMI hotkeys (device grab), but flw1 maps nothing:
KeyProg3 passes through on virtual "InputPlumber Keyboard" as KEY_PROG3 (202).

No gamepad QuickAccess, no KeyMute, no volume keys.
"""
from __future__ import annotations

import argparse
import json
import os
import pwd
import select
import socket
import struct
import subprocess
import sys
import time
from pathlib import Path

EV_KEY = 0x01
EVENT_SIZE = 24
# Linux KEY_PROG3 — chassis 控制中心 when flw1 has empty mapping (passthrough)
KEY_PROG3 = 202
CODES = {KEY_PROG3}
COOLDOWN_S = float(os.environ.get("AIPC_CC_COOLDOWN", "3"))
ONCE = os.environ.get(
    "AIPC_VOICE_ONCE",
    "/home/birdyo/.local/bin/aipc-voice-once",
)
KB_NAMES = (
    "InputPlumber Keyboard",
)
STATE_PATH = Path("/run/aipc/command-center.json")


def publish_state(availability: str, state: str, detail: str) -> None:
    data = {
        "availability": availability,
        "summary": detail,
        "button": {"state": state, "updated_at": int(time.time())},
    }
    try:
        STATE_PATH.parent.mkdir(mode=0o755, exist_ok=True)
        temporary = STATE_PATH.with_suffix(".tmp")
        temporary.write_text(json.dumps(data), encoding="utf-8")
        temporary.replace(STATE_PATH)
    except OSError:
        pass


def find_keyboard() -> str | None:
    for d in Path("/dev/input").glob("event*"):
        try:
            name = (Path("/sys/class/input") / d.name / "device/name").read_text().strip()
        except OSError:
            continue
        if name in KB_NAMES:
            return str(d)
    return None


def desktop_env() -> dict[str, str]:
    env = os.environ.copy()
    run_user = Path("/run/user")
    if not run_user.is_dir():
        return env
    for entry in sorted(run_user.iterdir(), key=lambda p: p.name):
        if not entry.name.isdigit():
            continue
        bus = entry / "bus"
        if not bus.exists():
            continue
        uid = int(entry.name)
        try:
            pw = pwd.getpwuid(uid)
        except KeyError:
            continue
        if pw.pw_name in ("root", "nobody"):
            continue
        env["DISPLAY"] = env.get("DISPLAY") or ":0"
        env["XDG_RUNTIME_DIR"] = str(entry)
        env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus}"
        env["HOME"] = pw.pw_dir
        env["USER"] = pw.pw_name
        env["LOGNAME"] = pw.pw_name
        env["AIPC_CC_AS"] = pw.pw_name
        local = Path(pw.pw_dir) / ".local/bin/aipc-voice-once"
        if local.is_file():
            env["AIPC_VOICE_ONCE_RESOLVED"] = str(local)
        return env
    return env


def _wake_ptt(env: dict[str, str]) -> bool:
    """Ask wake service to start command capture on its single mic stream."""
    xdg = env.get("XDG_RUNTIME_DIR", "/run/user/1000")
    socks = [
        Path(xdg) / "aipc-wake.sock",
        Path(f"/tmp/aipc-wake-{os.geteuid()}.sock"),
        Path("/tmp/aipc-wake-1000.sock"),
    ]
    for sp in socks:
        if not sp.exists():
            continue
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(0.5)
            s.connect(str(sp))
            s.sendall(b"ptt\n")
            s.close()
            print(f"aipc-command-center: ptt → wake sock {sp}", flush=True)
            return True
        except OSError as exc:
            print(f"aipc-command-center: wake sock {sp} fail: {exc}", flush=True)
    return False


def _wake_sock_present(env: dict[str, str]) -> bool:
    xdg = env.get("XDG_RUNTIME_DIR", "/run/user/1000")
    for sp in (
        Path(xdg) / "aipc-wake.sock",
        Path(f"/tmp/aipc-wake-{os.geteuid()}.sock"),
        Path("/tmp/aipc-wake-1000.sock"),
    ):
        if sp.exists():
            return True
    return False


def trigger() -> None:
    env = desktop_env()
    # Prefer wake pipeline (async single-mic); no second arecord.
    # When wake is up, PTT continues the same multi-turn session — never spawn
    # a parallel aipc-voice-once (that looked like a brand-new session).
    if _wake_ptt(env):
        return
    if _wake_sock_present(env):
        # Sock exists but send failed — retry once, still no spawn-once
        time.sleep(0.05)
        if _wake_ptt(env):
            return
        print(
            "aipc-command-center: wake sock present but ptt failed — skip spawn once",
            flush=True,
        )
        return
    cmd = env.pop("AIPC_VOICE_ONCE_RESOLVED", None) or ONCE
    # Keep the same agent session id as wake pipeline when falling back
    argv = [cmd, "--vad", "--session-id", "voice-assistant"]
    as_user = env.get("AIPC_CC_AS")
    if as_user and os.geteuid() == 0 and as_user != "root":
        argv = ["runuser", "-u", as_user, "--", *argv]
    log = Path("/tmp/aipc-voice-once-from-cc.log")
    try:
        lf = open(log, "ab", buffering=0)  # noqa: SIM115
    except OSError:
        lf = subprocess.DEVNULL
    print(f"aipc-command-center: wake offline; spawn {' '.join(argv)}", flush=True)
    subprocess.Popen(argv, env=env, stdout=lf, stderr=lf, start_new_session=True)

def loop(path: str) -> int:
    print(
        f"aipc-command-center: watching {path} for KEY_PROG3 ({KEY_PROG3}) only",
        flush=True,
    )
    f = open(path, "rb")
    poll = select.poll()
    poll.register(f.fileno(), select.POLLIN)
    last = 0.0
    try:
        while True:
            if not poll.poll(1000):
                if not Path(path).exists():
                    print("aipc-command-center: device gone, exit for restart", flush=True)
                    return 1
                continue
            data = f.read(EVENT_SIZE)
            if len(data) < EVENT_SIZE:
                continue
            _s, _u, typ, code, value = struct.unpack("llHHi", data)
            if typ != EV_KEY or value != 1:
                continue
            if code not in CODES:
                continue
            now = time.monotonic()
            if now - last < COOLDOWN_S:
                continue
            last = now
            print(f"aipc-command-center: KEY_PROG3 pressed → voice", flush=True)
            publish_state("available", "pressed", "Command Center button pressed")
            trigger()
    except KeyboardInterrupt:
        return 0
    finally:
        f.close()


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("--self-test", action="store_true")
    args = ap.parse_args()
    if args.self_test:
        assert CODES == {KEY_PROG3}
        print("aipc-command-center-listen: self-test OK")
        return 0
    path = find_keyboard()
    if not path:
        publish_state("unavailable", "unavailable", "InputPlumber Keyboard not found")
        print(
            "aipc-command-center: InputPlumber Keyboard not found (is inputplumber up?)",
            file=sys.stderr,
        )
        return 2
    publish_state("available", "idle", "Command Center button ready")
    return loop(path)


if __name__ == "__main__":
    raise SystemExit(main())
