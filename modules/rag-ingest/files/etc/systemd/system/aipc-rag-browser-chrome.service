[Unit]
Description=AIPC RAG watcher — Chrome history (consent-gated)
After=network-online.target rag-embedder.service postgres.service
Requires=rag-embedder.service postgres.service

[Service]
Type=simple
Environment=PYTHONPATH=/usr/lib/aipc-rag
ExecStart=/usr/lib/aipc-rag/venv/bin/python3 -m aipc_rag.browser --browser chrome
Restart=on-failure

[Install]
WantedBy=default.target
