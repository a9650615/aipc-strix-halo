# Authoritative always-on wake policy (arm / thrash / reprompt).
# Loaded first by aipc_voice_wake.py (_preload_wake_policy_file) so this file
# wins over contradictory systemd drop-in Environment= mazes.
# Docs: docs/superpowers/specs/2026-07-16-voice-session-runtime-design.md
#
# Always-on may stay disabled for safety; policy still applies when started.

# --- Anti-ghost (prefer miss) ---
AIPC_WAKE_ALLOW_FUZZY_PROMOTE=0
AIPC_WAKE_PROMOTE_SCORE=90
AIPC_WAKE_CANDIDATE_SCORE=70

# --- Energy gate (harder ambient open) ---
AIPC_WAKE_ENERGY=2800
AIPC_WAKE_ENERGY_FRAMES=8
AIPC_WAKE_COOLDOWN=10
AIPC_WAKE_CAPTURE_S=2.4

# --- STT thrash protection after consecutive non-arms ---
AIPC_WAKE_MISS_BACKOFF_BASE=6
AIPC_WAKE_MISS_BACKOFF_CAP=90

# --- Intentional empty/junk ---
AIPC_WAKE_MAX_REPROMPTS=1
AIPC_WAKE_REPROMPT_TEXT=沒聽清，請再說一次

# --- Command capture (mid-phrase safe) ---
AIPC_WAKE_CMD_MAX_S=18
AIPC_WAKE_CMD_END_SILENCE_MS=1300
AIPC_WAKE_CMD_END_SILENCE_FAST_MS=950
AIPC_WAKE_CMD_MIN_SPEECH_MS=850
AIPC_WAKE_CMD_TEXT_STABLE_S=1.4
AIPC_WAKE_CMD_TEXT_STABLE_MIN_SPEECH_S=1.6
AIPC_WAKE_CMD_START_TIMEOUT=8

# --- Follow-up: when re-enabled, prefer less aggressive direct UI ---
# (probe mode is future; keep direct off by default for stability)
AIPC_WAKE_FOLLOWUP_DIRECT=0
AIPC_WAKE_FOLLOWUP_POST_TTS_S=0.9
AIPC_WAKE_FOLLOWUP_SILENCE_S=2.6
AIPC_WAKE_FOLLOWUP_JUNK_MAX=2

# --- Echo / denoise (wake clip) ---
AIPC_WAKE_ECHO_GATE=0
AIPC_WAKE_DENOISE=0
