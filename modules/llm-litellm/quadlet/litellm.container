[Unit]
Description=LiteLLM proxy gateway for AIPC
# Ollama/122B is optional (often stopped to save ~80GB UMA). Lemonade is the
# closed-loop default backend. Do not Requires=ollama — that takes LiteLLM
# down when 122B is disabled.
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/berriai/litellm@sha256:afdc3cc37493d4f86d485ad7ac4445e7154c568a8d47c01bad15c9cf062c66b5
ContainerName=litellm
Network=host
Volume=/etc/aipc/litellm/config.yaml:/app/config.yaml:ro,Z
# 0012 memory scheduler: hook module + manifest it budgets against. litellm
# imports "scheduler_hook.scheduler" relative to /app (its workdir).
Volume=/etc/aipc/litellm/scheduler_hook.py:/app/scheduler_hook.py:ro,Z
Volume=/etc/aipc/models/models.yaml:/app/models.yaml:ro,Z
Exec=--config /app/config.yaml --host 127.0.0.1 --port 4000
EnvironmentFile=/etc/aipc/env.d/llm-litellm/cloud-keys.env
# Scheduler tunables (defaults live in scheduler_hook.py; override here).
# Budget: GTT ceiling is 122GiB, but hardware-observed 2026-07-12 the
# non-model working set (desktop + hermes + services) runs ~47GB, so 96
# would let ornith+coder-122b coexist and OOM real RAM. 80 forces the
# scheduler to evict down to the 122B + small residents during coding
# sessions (user directive: never OOM; swap acceptable).
Environment=AIPC_SCHED_BUDGET_GB=80
# Real-memory gate headroom (see scheduler_hook.py): admission additionally
# requires host MemAvailable >= model size + this, because the static
# budget cannot see the desktop's actual (spiky) working set — the
# 2026-07-12 18:32 kernel OOM (plasmashell/zen/hermes-webui killed) was a
# ledger-admitted load on a browser-heavy desktop.
Environment=AIPC_SCHED_HEADROOM_GB=10
# ComfyUI GTT reclamation (0016): before falling to swap-backed admission,
# ask an idle ComfyUI to free its cache. Host netns is shared (Network=host
# above), so 127.0.0.1:8188 reaches the user's ComfyUI. Unset -> disabled,
# scheduler behaves exactly as 0012. Uncomment to enable.
# Environment=AIPC_SCHED_COMFY_BASE=http://127.0.0.1:8188
# Environment=AIPC_SCHED_COMFY_RECLAIM=1

[Service]
Restart=always
TimeoutStartSec=90

[Install]
WantedBy=default.target
