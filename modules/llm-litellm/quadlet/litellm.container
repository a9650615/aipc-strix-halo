[Unit]
Description=LiteLLM proxy gateway for AIPC
# Ollama/122B is optional (often stopped to save ~80GB UMA). Lemonade is the
# closed-loop default backend. Do not Requires=ollama — that takes LiteLLM
# down when 122B is disabled.
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/berriai/litellm@sha256:afdc3cc37493d4f86d485ad7ac4445e7154c568a8d47c01bad15c9cf062c66b5
ContainerName=litellm
Network=host
Volume=/etc/aipc/litellm/config.yaml:/app/config.yaml:ro,Z
Exec=--config /app/config.yaml --host 127.0.0.1 --port 4000
EnvironmentFile=/etc/aipc/env.d/llm-litellm/cloud-keys.env

[Service]
Restart=always
TimeoutStartSec=90

[Install]
WantedBy=default.target
