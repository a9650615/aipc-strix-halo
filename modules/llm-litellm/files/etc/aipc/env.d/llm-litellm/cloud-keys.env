# Cloud API keys for gateway aliases. Populated on the host (never commit
# real values). litellm.container's EnvironmentFile= requires this path to
# exist (quadlet does not support systemd's "-/path" optional-file prefix).
#
# Direct vendor keys (optional; used by main-cloud / gpt4o-cloud / …):
#   ANTHROPIC_API_KEY=
#   OPENAI_API_KEY=
#   GEMINI_API_KEY=
#   Z_AI_API_KEY=
#
# CLIProxy-backed models (gpt-5.6-*, claude-*, …) need:
#   CLIPROXY_API_KEY=
# Same value Hermes uses in ~/.hermes/.env — LiteLLM only holds the local
# proxy key; Codex/Claude credentials stay inside CLIProxy.
