#!/bin/sh
# aipc-models-dir-setup — resolve /var/lib/aipc-models to the primary user's
# home directory. Runs at real boot (never at image build) since the target
# user's home is only known on the deployed machine, and content written
# under /var during build isn't part of the ostree commit anyway.
set -eu

[ -e /var/lib/aipc-models ] && exit 0

target_user=$(awk -F: '$3 >= 1000 && $3 < 60000 {print $1; exit}' /etc/passwd || true)
if [ -z "${target_user:-}" ]; then
  echo "aipc-models-dir-setup: no primary user found — using /var/lib/aipc-models directly" >&2
  mkdir -p /var/lib/aipc-models
  exit 0
fi

target_home=$(getent passwd "$target_user" | cut -d: -f6)
real_dir="${target_home}/aipc-models"

mkdir -p "$real_dir"
chown "$target_user:$target_user" "$real_dir"

# SELinux: user_home_t (the default label under a home dir) is not
# accessible to container_t, and podman's Volume=...:Z relabels whatever
# path is literally in the quadlet — since that's the /var/lib/aipc-models
# symlink, relabeling lands on the symlink inode, not the real target this
# resolves to. Register + apply container_file_t directly on the real dir
# so the container can actually read/write into it.
if command -v semanage >/dev/null 2>&1; then
  semanage fcontext -a -t container_file_t "${real_dir}(/.*)?" 2>/dev/null || true
  restorecon -R "$real_dir" 2>/dev/null || true
fi

ln -s "$real_dir" /var/lib/aipc-models
