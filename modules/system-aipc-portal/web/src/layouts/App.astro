---
import { ClientRouter } from "astro:transitions";
import "../styles/app.css";
const { title = "AIPC Control Center" } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <header><a class="brand" href="/">AIPC <span>Control Center</span></a><nav><a href="/#home">Home</a><a href="/#device">Device</a><a href="/#ai">AI &amp; Voice</a><a href="/#services">Services</a><a href="/memory" data-astro-reload>Memory</a></nav></header>
    <main><slot /></main>
  </body>
</html>
