---
import App from "../layouts/App.astro";
---
<App title="AIPC 記憶">
  <section class="hero">
    <p class="eyebrow" data-i18n="memory.eyebrow">MEM0 · 長期記憶</p>
    <h1 data-i18n="memory.title">記憶</h1>
    <p id="summary" data-i18n="memory.loading">正在載入記憶…</p>
  </section>
  <section class="controls" aria-label="Memory filters">
    <input id="query" data-i18n-placeholder="memory.search.ph" placeholder="語意搜尋…" />
    <select id="user"><option value="" data-i18n="memory.user">user_id（全部）</option></select>
    <select id="agent"><option value="" data-i18n="memory.agent">agent_id（全部）</option></select>
    <select id="app"><option value="" data-i18n="memory.app">app_id（全部）</option></select>
    <button id="search" type="button" data-i18n="memory.search">搜尋</button>
    <button id="list" type="button" data-i18n="memory.list">列出全部</button>
  </section>
  <section aria-label="Stored memories"><ul id="memories"></ul></section>
  <script>
    import { t, applyDom } from "../scripts/i18n.js";

    const summary = document.querySelector("#summary");
    const value = (id) => document.querySelector(`#${id}`).value.trim();
    const scope = () => Object.fromEntries(
      [["user_id", value("user")], ["agent_id", value("agent")], ["app_id", value("app")]].filter(([, v]) => v)
    );

    function renderRows(items) {
      summary.textContent = t("memory.count", { n: items.length });
      document.querySelector("#memories").replaceChildren(...items.map((m) => {
        const row = document.createElement("li");
        const text = document.createElement("p");
        text.textContent = m.memory || m.data || JSON.stringify(m);
        const meta = document.createElement("small");
        meta.textContent = [
          m.user_id && `user:${m.user_id}`,
          m.agent_id && `agent:${m.agent_id}`,
          m.metadata?.app_id && `app:${m.metadata.app_id}`,
          m.created_at?.slice(0, 19),
          typeof m.score === "number" && `score:${m.score.toFixed(3)}`,
        ].filter(Boolean).join(" · ");
        const del = Object.assign(document.createElement("button"), { textContent: t("memory.delete") });
        del.onclick = async () => {
          if (!confirm(t("memory.delete.confirm"))) return;
          await fetch(`/api/v1/memories/${m.id}`, { method: "DELETE" });
          list();
        };
        row.append(text, meta, del);
        return row;
      }));
    }

    async function list() {
      try {
        const params = new URLSearchParams({ ...scope(), limit: "100" });
        const data = await fetch(`/api/v1/memories?${params}`).then((r) => r.ok ? r.json() : Promise.reject(r.status));
        renderRows(data.results || []);
      } catch {
        summary.textContent = t("memory.unavailable");
      }
    }

    async function search() {
      const query = value("query");
      if (!query) return list();
      try {
        const data = await fetch("/api/v1/memories/search", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ query, ...scope(), limit: 20 }),
        }).then((r) => r.ok ? r.json() : Promise.reject(r.status));
        renderRows(data.results || []);
      } catch {
        summary.textContent = t("memory.unavailable");
      }
    }

    async function loadFacets() {
      try {
        const facets = await fetch("/api/v1/memories/facets").then((r) => r.ok ? r.json() : Promise.reject(r.status));
        for (const [id, key] of [["user", "user_id"], ["agent", "agent_id"], ["app", "app_id"]]) {
          const select = document.querySelector(`#${id}`);
          for (const v of facets[key] || []) select.append(new Option(v, v));
        }
      } catch { /* dropdowns stay usable */ }
    }

    document.querySelector("#search").onclick = search;
    document.querySelector("#list").onclick = list;
    document.querySelector("#query").addEventListener("keydown", (e) => { if (e.key === "Enter") search(); });
    window.addEventListener("aipc:lang", () => {
      applyDom(document);
      // Re-label static control option zeros without wiping facets
      const map = [
        ["user", "memory.user"],
        ["agent", "memory.agent"],
        ["app", "memory.app"],
      ];
      for (const [id, key] of map) {
        const opt = document.querySelector(`#${id} option[value=""]`);
        if (opt) opt.textContent = t(key);
      }
      list();
    });
    applyDom(document);
    loadFacets();
    list();
  </script>
</App>
