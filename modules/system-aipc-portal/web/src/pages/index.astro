---
import App from "../layouts/App.astro";
---
<App title="AIPC 控制中心">
  <section id="home" class="hero">
    <p class="eyebrow" data-i18n="home.eyebrow">本機 · 127.0.0.1</p>
    <h1 data-i18n="home.title">控制中心</h1>
    <p id="summary" class="hero-summary" data-i18n="home.loading">正在載入系統狀態…</p>
    <div class="hero-actions">
      <button id="baseline" type="button" data-i18n="home.baseline">啟動基線服務</button>
      <a class="button-link" href="/models" data-astro-reload data-i18n="nav.models">模型調度</a>
      <a class="button-link" href="/agents" data-astro-reload data-i18n="nav.agents">代理人</a>
      <a class="button-link" href="/memory" data-astro-reload data-i18n="nav.memory">記憶</a>
    </div>
  </section>

  <section class="grid home-grid" aria-label="System overview">
    <article id="platform" class="home-card">
      <p class="eyebrow">AI MAX+ 395</p>
      <h2 data-i18n="home.platform">平台</h2>
      <p class="status status-line" data-i18n="home.waiting.platform">等待遙測…</p>
      <ul class="metric-list" id="platform-metrics"></ul>
    </article>

    <article id="device" class="home-card device-card">
      <p class="eyebrow">Z13 FLOW · LIVE I/O</p>
      <h2 data-i18n="home.device">裝置 / 機身</h2>
      <svg class="chassis-map" viewBox="0 0 320 180" role="img" aria-label="Z13 Flow chassis map">
        <path class="chassis-body" d="M66 28h188l24 124H42z"></path>
        <circle id="port0-dot" cx="60" cy="118" r="9" class="dim"></circle>
        <text x="60" y="145" text-anchor="middle" class="chassis-label">C0</text>
        <circle id="port1-dot" cx="120" cy="150" r="9" class="dim"></circle>
        <text x="120" y="172" text-anchor="middle" class="chassis-label">C1</text>
        <rect id="typea-dot" x="188" y="140" width="18" height="12" rx="2" class="dim typea-port"></rect>
        <text x="197" y="172" text-anchor="middle" class="chassis-label">A</text>
        <circle id="command-button" cx="266" cy="80" r="10" class="dim"></circle>
        <text x="266" y="58" text-anchor="middle" class="chassis-label">btn</text>
      </svg>
      <p class="status status-line" data-i18n="home.waiting.device">等待裝置狀態…</p>
      <div class="pill-row" id="device-pills"></div>
      <ul class="metric-list" id="device-metrics"></ul>
    </article>

    <article id="npu" class="home-card">
      <p class="eyebrow">XDNA NPU</p>
      <h2 data-i18n="home.npu">NPU 活動</h2>
      <p class="status status-line" data-i18n="home.waiting.npu">等待 NPU 狀態…</p>
      <ul class="metric-list" id="npu-models"></ul>
      <small id="npu-foot" class="foot-line"></small>
    </article>

    <article id="ai" class="home-card">
      <p class="eyebrow">VOICE &amp; AGENT</p>
      <h2 data-i18n="home.runtime">執行期</h2>
      <p class="status status-line" data-i18n="home.waiting.runtime">等待服務狀態…</p>
      <ul class="metric-list" id="runtime-models"></ul>
      <small id="runtime-foot" class="foot-line"></small>
    </article>

    <article id="ops" class="home-card ops-panel">
      <div class="ops-head">
        <div>
          <p class="eyebrow" data-i18n="home.ops.eyebrow">營運</p>
          <h2 data-i18n="home.ops.title">服務與即時工作</h2>
        </div>
        <p id="ops-summary" class="ops-summary muted">—</p>
      </div>
      <div class="ops-body">
        <div class="ops-col">
          <div class="ops-col-head">
            <h3 data-i18n="home.ops.services">服務</h3>
            <span id="ops-svc-count" class="chip muted">0</span>
          </div>
          <div id="ops-services" class="ops-list" role="list"></div>
        </div>
        <div class="ops-col">
          <div class="ops-col-head">
            <h3 data-i18n="home.ops.live">即時工作</h3>
            <span id="ops-auto-count" class="chip muted">0</span>
          </div>
          <div id="ops-automation" class="ops-list" role="list"></div>
        </div>
      </div>
    </article>
  </section>

  <script>
    import { t, applyDom, stateLabel } from "../scripts/i18n.js";
    import { createJsonPoller } from "../scripts/poll.js";

    const $ = (sel) => document.querySelector(sel);
    let poller = null;
    const show = (id, text) => {
      const el = $(`#${id} .status`);
      if (el && el.textContent !== text) el.textContent = text;
    };
    const shortName = (name, max = 28) => {
      const s = String(name || "model");
      return s.length > max ? s.slice(0, max - 1) + "…" : s;
    };
    const post = async (path) => { await fetch(path, { method: "POST" }); poller?.refresh(); };

    let events = null;
    let lastPayload = "";

    function cleanup() {
      poller?.stop();
      poller = null;
      if (events) { try { events.close(); } catch {} events = null; }
    }
    document.addEventListener("astro:before-preparation", cleanup, { once: true });
    window.addEventListener("pagehide", cleanup, { once: true });

    function pill(text, kind = "na") {
      const span = document.createElement("span");
      span.className = `pill pill-${kind}`;
      span.textContent = text;
      return span;
    }

    function metric(label, value) {
      const li = document.createElement("li");
      const k = document.createElement("span");
      k.className = "k";
      k.textContent = label;
      k.title = label;
      const v = document.createElement("span");
      v.className = "v";
      v.textContent = value;
      v.title = value;
      li.append(k, v);
      return li;
    }

    function setActive(el, on) {
      if (!el) return;
      el.classList.toggle("lit", !!on);
      el.classList.toggle("dim", !on);
    }

    function fillList(el, rows) {
      if (!el) return;
      // Avoid full DOM rebuild when content is identical (stops layout thrash).
      const key = rows.map((r) => r[0] + "\0" + r[1]).join("\n");
      if (el.dataset.key === key) return;
      el.dataset.key = key;
      el.replaceChildren(...rows.map(([k, v]) => metric(k, v)));
    }

    function renderPlatform(p) {
      show("platform", p?.summary || "—");
      const rows = [];
      if (p?.chassis) rows.push([t("home.metric.chassis"), p.chassis]);
      if (p?.cpu) rows.push([t("home.metric.cpu"), p.cpu]);
      if (p?.hostname) rows.push([t("home.metric.host"), p.hostname]);
      if (p?.os_name) {
        rows.push([t("home.metric.os"), [p.os_name, p.os_version].filter(Boolean).join(" ")]);
      }
      if (p?.kernel) rows.push([t("home.metric.kernel"), p.kernel]);
      if (p?.mem_available_gb != null && p?.mem_total_gb != null) {
        rows.push([t("home.metric.ram"), `${Number(p.mem_available_gb).toFixed(0)} / ${Number(p.mem_total_gb).toFixed(0)} GiB`]);
      }
      if (p?.gtt_used_gb != null && p?.gtt_total_gb != null) {
        rows.push([t("home.metric.gtt"), `${Number(p.gtt_used_gb).toFixed(1)} / ${Number(p.gtt_total_gb).toFixed(0)} GiB`]);
      }
      if (p?.profile) {
        const choices = (p.profile_choices || []).join(" / ");
        rows.push([t("home.metric.profile"), choices ? `${p.profile} (${choices})` : String(p.profile)]);
      }
      fillList($("#platform-metrics"), rows);
    }

    function renderDevice(device) {
      const ports = device?.io?.ports || device?.io?.type_c?.ports || [];
      const typeA = device?.io?.type_a?.ports || [];
      const connected = Number(device?.ports_connected ?? ports.filter((p) => p.state === "connected").length);
      const total = Number(device?.ports_total ?? ports.length);
      const aConn = Number(device?.type_a_connected ?? typeA.filter((p) => p.state === "connected").length);
      const aTotal = Number(device?.type_a_total ?? typeA.length);
      show("device", device?.summary || t("home.device.unavailable"));

      const port0 = ports.find((p) => p.id === "port0");
      const port1 = ports.find((p) => p.id === "port1");
      setActive($("#port0-dot") || $("#dock"), port0?.state === "connected");
      setActive($("#port1-dot"), port1?.state === "connected");
      const typeAOn = aConn > 0;
      const typeAEl = $("#typea-dot");
      if (typeAEl) {
        typeAEl.classList.toggle("lit", typeAOn);
        typeAEl.classList.toggle("dim", !typeAOn);
      }
      const buttonOn = device?.button_state === "pressed" || device?.button_state === "active";
      setActive($("#command-button"), buttonOn);

      const pills = $("#device-pills");
      if (pills) {
        const lang = document.documentElement.dataset.lang || "zh";
        const key = `pills|${connected}/${total}|${aConn}/${aTotal}|${device?.source}|${device?.button_state || ""}|${JSON.stringify(ports)}|${JSON.stringify(typeA)}|${lang}`;
        if (pills.dataset.key !== key) {
          pills.dataset.key = key;
          const nodes = [];
          nodes.push(pill(`C ${connected}/${total || 0}`, connected > 0 ? "ok" : "na"));
          nodes.push(pill(`A ${aConn}/${aTotal || 0}`, aConn > 0 ? "ok" : "na"));
          nodes.push(pill(device?.chassis || "Z13", "ok"));
          if (device?.source === "io-only") nodes.push(pill(t("home.button.offline"), "wait"));
          else if (device?.button_state) nodes.push(pill(t("home.button.state", { state: device.button_state }), "ok"));
          else nodes.push(pill(t("home.button.unknown"), "na"));
          pills.replaceChildren(...nodes);
        }
      }

      const drows = [];
      drows.push([t("home.typec"), ports.length ? `${connected}/${total}` : t("home.typec.none")]);
      for (const p of ports) {
        const link = p.state === "connected" ? t("home.port.link") : t("home.port.idle");
        const roles = [
          p.data_role && `data:${p.data_role}`,
          p.power_role && `pwr:${p.power_role}`,
          p.panel && `panel:${p.panel}`,
        ].filter(Boolean).join(" · ");
        drows.push([`C · ${p.id}`, roles ? `${link} · ${roles}` : link]);
      }
      drows.push([t("home.typea"), typeA.length ? `${aConn}/${aTotal}` : t("home.typea.none")]);
      for (const p of typeA) {
        const link = p.state === "connected" ? t("home.port.link") : t("home.port.idle");
        const who = p.product || p.manufacturer || "";
        drows.push([`A · ${p.id}`, who ? `${link} · ${who}` : link]);
      }
      if (device?.source === "io-only") {
        drows.push([t("home.metric.button"), t("home.button.offline")]);
      } else if (device?.button_state) {
        drows.push([t("home.metric.button"), String(device.button_state)]);
      }
      fillList($("#device-metrics"), drows);
    }

    function renderNpu(npu) {
      show("npu", npu?.summary || "—");
      const entries = npu?.entries || (npu?.models || []).map((name) => ({ name }));
      const rows = entries.length
        ? entries.map((e) => {
            const bits = [
              e.device || "npu",
              e.recipe,
              e.pinned ? "pinned" : null,
              e.ctx ? `ctx ${Number(e.ctx) >= 1024 ? Math.round(Number(e.ctx) / 1024) + "k" : e.ctx}` : null,
              e.status,
            ].filter(Boolean);
            return [shortName(e.name || "model"), bits.join(" · ")];
          })
        : [[t("home.metric.models"), t("home.none.models")]];
      fillList($("#npu-models"), rows);
      const foot = $("#npu-foot");
      if (foot) {
        const text = t("home.foot.lemonade", {
          service: npu?.service || "unknown",
          activity: npu?.activity || "",
        });
        if (foot.textContent !== text) foot.textContent = text;
      }
    }

    function renderRuntime(runtime) {
      show("ai", runtime?.summary || "—");
      const models = runtime?.models || [];
      const rows = models.length
        ? models.map((m) => {
            const bits = [m.backend, m.device, m.pinned ? "pinned" : null, m.status].filter(Boolean);
            return [shortName(m.name || "model"), bits.join(" · ")];
          })
        : [[t("home.metric.loaded"), t("home.none.reported")]];
      fillList($("#runtime-models"), rows);
      const foot = $("#runtime-foot");
      if (foot) {
        const v = runtime?.voice_services_up;
        const tot = runtime?.voice_services_total;
        const text = (v != null && tot != null)
          ? t("home.foot.voice", { v, t: tot, m: runtime?.model_count || 0 })
          : "";
        if (foot.textContent !== text) foot.textContent = text;
      }
    }

    function serviceLabel(title) {
      // Prefer short English label; drop parenthetical / fullwidth notes.
      const raw = String(title || "").trim();
      const cut = raw.replace(/[（(].*$/, "").trim();
      return cut || raw;
    }

    // Prefer backend truth (ops.py → snapshot.can_start / display_state); fall back
    // only when older API payloads omit the fields.
    function serviceState(s) {
      if (s.display_state) return String(s.display_state);
      const unit = String(s.state || "").trim();
      if (unit === "n/a") {
        if (s.health === true) return "ready";
        if (s.health === false) return "down";
        return "n/a";
      }
      return unit || "unknown";
    }

    function serviceKind(s) {
      const st = serviceState(s);
      if (st === "active" || st === "ready") return "ok";
      if (st === "activating" || st === "reloading" || st === "deactivating") return "wait";
      if (st === "failed" || st === "inactive" || st === "down") return "bad";
      return "na";
    }

    function serviceIsUp(s) {
      const st = serviceState(s);
      return st === "active" || st === "ready";
    }

    function serviceCanStart(s) {
      if (typeof s.can_start === "boolean") return s.can_start;
      const unit = String(s.state || "").trim();
      if (!unit || unit === "n/a") return false;
      if (serviceIsUp(s)) return false;
      if (unit === "activating" || unit === "reloading") return false;
      return true;
    }

    function serviceGroup(id) {
      if (["lemonade", "litellm"].includes(id)) return "LLM";
      if (["sensevoice", "kokoro", "pipecat", "mem0"].includes(id)) return "Voice";
      if (["agent-activity", "hermes-webui"].includes(id)) return "Agent";
      return "System";
    }

    function renderOps(services, jobs) {
      const root = $("#ops-services");
      const auto = $("#ops-automation");
      if (!root || !auto) return;
      const key = JSON.stringify({ services, jobs });
      if (root.dataset.key === key) return;
      root.dataset.key = key;

      const list = services || [];
      const up = list.filter(serviceIsUp).length;
      const need = list.filter(serviceCanStart).length;
      const svcCount = $("#ops-svc-count");
      const autoCount = $("#ops-auto-count");
      if (svcCount) svcCount.textContent = `${up}/${list.length}`;
      if (autoCount) autoCount.textContent = `${(jobs || []).length}`;
      const sum = $("#ops-summary");
      if (sum) {
        sum.textContent = need
          ? t("home.ops.need_start", { n: need, j: (jobs || []).length })
          : t("home.ops.healthy", { up, total: list.length, j: (jobs || []).length });
      }

      const groups = ["LLM", "Voice", "Agent", "System"];
      const by = Object.fromEntries(groups.map((g) => [g, []]));
      for (const s of list) {
        const g = s.group || serviceGroup(s.id);
        (by[g] || by.System).push(s);
      }

      const nodes = [];
      for (const g of groups) {
        const rows = by[g];
        if (!rows.length) continue;
        const label = document.createElement("div");
        label.className = "ops-group-label";
        label.textContent = t(`home.group.${g}`);
        nodes.push(label);
        for (const s of rows) {
          const row = document.createElement("div");
          row.className = "ops-row";
          row.setAttribute("role", "listitem");
          const main = document.createElement("div");
          main.className = "ops-main";
          const title = document.createElement("span");
          title.className = "ops-title";
          title.textContent = serviceLabel(s.title);
          title.title = s.title || s.id;
          const st = serviceState(s);
          const badge = pill(stateLabel(st), serviceKind(s));
          main.append(title, badge);
          const actions = document.createElement("div");
          actions.className = "ops-actions";
          if (serviceCanStart(s)) {
            const button = Object.assign(document.createElement("button"), {
              type: "button",
              textContent: t("btn.start"),
              className: "ops-btn",
            });
            button.onclick = () => post(`/services/${s.id}/start`);
            actions.append(button);
          }
          if (s.ui) {
            const link = Object.assign(document.createElement("a"), {
              textContent: t("btn.open"),
              href: s.ui,
              target: "_blank",
              rel: "noopener",
              className: "ops-link",
            });
            actions.append(link);
          }
          row.append(main, actions);
          nodes.push(row);
        }
      }
      root.replaceChildren(...nodes);

      if (!(jobs || []).length) {
        const empty = document.createElement("div");
        empty.className = "ops-empty";
        const p1 = document.createElement("p");
        p1.textContent = t("home.ops.empty");
        const p2 = document.createElement("p");
        p2.className = "muted";
        p2.append(document.createTextNode(t("home.ops.empty.hint") + " "));
        const a = Object.assign(document.createElement("a"), {
          href: "/agents",
          textContent: t("nav.agents"),
        });
        a.setAttribute("data-astro-reload", "");
        p2.append(a);
        empty.append(p1, p2);
        auto.replaceChildren(empty);
        return;
      }
      auto.replaceChildren(...jobs.map((job) => {
        const row = document.createElement("div");
        row.className = "ops-row";
        row.setAttribute("role", "listitem");
        const main = document.createElement("div");
        main.className = "ops-main";
        const title = document.createElement("span");
        title.className = "ops-title";
        title.textContent = job.provider || job.task_id || "job";
        const badge = pill(stateLabel(job.state || "unknown"), job.state === "running" ? "run" : "na");
        main.append(title, badge);
        const actions = document.createElement("div");
        actions.className = "ops-actions";
        if (job.task_id && (job.state === "running" || job.state === "cancelling")) {
          const button = Object.assign(document.createElement("button"), {
            type: "button",
            textContent: t("btn.cancel"),
            className: "ops-btn danger",
          });
          button.onclick = () => post(`/automation/${job.task_id}/cancel`);
          actions.append(button);
        }
        row.append(main, actions);
        return row;
      }));
    }

    function applyDashboard(data) {
      const sig = JSON.stringify({
        s: data.summary,
        p: data.platform,
        d: data.device && {
          summary: data.device.summary,
          ports_connected: data.device.ports_connected,
          ports_total: data.device.ports_total,
          type_a_connected: data.device.type_a_connected,
          source: data.device.source,
          button_state: data.device.button_state,
          io: data.device.io,
        },
        n: data.npu && { summary: data.npu.summary, entries: data.npu.entries, service: data.npu.service, activity: data.npu.activity },
        r: data.runtime,
        svc: data.services,
        a: data.automation,
      });
      if (sig === lastPayload) return;
      lastPayload = sig;
      renderPlatform(data.platform || {});
      renderDevice(data.device || {});
      renderNpu(data.npu || {});
      renderRuntime(data.runtime || {});
      renderOps(data.services || [], data.automation || []);
      const sum = $("#summary");
      if (sum && sum.textContent !== (data.summary || "—")) {
        sum.textContent = data.summary || "—";
      }
    }

    applyDom(document);
    poller = createJsonPoller({
      url: "/api/v1/dashboard",
      intervalMs: 8000,
      onData: applyDashboard,
      onError: () => {
        const sum = $("#summary");
        if (sum) sum.textContent = t("home.unavailable");
      },
    });
    window.addEventListener("aipc:lang", () => {
      applyDom(document);
      lastPayload = "";
      poller?.refresh();
    });
    events = new EventSource("/api/v1/device/events");
    events.onmessage = ({ data }) => {
      try { renderDevice(JSON.parse(data)); } catch { /* ignore bad event */ }
    };
    $("#baseline").onclick = () => post("/ops/baseline/start");
  </script>
</App>
