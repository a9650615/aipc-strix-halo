#!/usr/bin/env python3
"""One-shot push-to-talk voice round trip (v0, text-out, no TTS, no wake word).

Scope cut per explicit user direction (phase-3-voice tasks 1.1, 5.1, 5.2):
record -> STT -> agent-orchestrator /chat -> desktop notification. No
CosyVoice/Kokoro TTS, no NPU wake-word classifier, no global hotkey — those
are separate, deferred pieces (tasks 1.2/2.x/4.x/6.x/7.x). Invoke this
manually until a hotkey/wake trigger lands.

Plain stdlib, no pipecat-ai: this is a 4-step sequential round trip (record,
two HTTP POSTs, notify) — pipecat-ai's frame-processor pipeline abstraction
is built for streaming multi-stage audio graphs (D1's full wake->STT->LLM
->TTS pipeline), which doesn't exist yet on either end (no wake service, no
TTS). Force-fitting that framework around two blocking HTTP calls would be
more code than the problem, not less. Revisit pipecat-ai once the streaming
pipeline (wake word, TTS, barge-in) is actually being built.

Assumed STT contract (voice-stt-sensevoice, port 9001, not implemented yet
as of this writing — reconcile against its real README/server.py):
    POST http://127.0.0.1:9001/transcribe
    Request:  raw WAV bytes, Content-Type: audio/wav (16 kHz mono S16_LE,
              matching what record_wav() below produces)
    Response: 200 {"text": "..."}  on success

agent-orchestrator's /chat contract (port 4100) is real and hardware-verified
(modules/agent-orchestrator) — {"text": ..., "session_id": ...} in,
{"text": ..., "task_id": ...} out.
"""
import argparse
import re
import array
import json
import os
import shutil
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request
import wave
from pathlib import Path

for _p in (
    Path("/usr/lib/aipc-voice"),
    Path("/var/lib/aipc-voice/lib"),
    Path.home() / ".local/lib/aipc-voice",
    Path(__file__).resolve().parents[1] / "lib/aipc-voice",
):
    if _p.is_dir():
        sys.path.insert(0, str(_p))
try:
    import aipc_voice_tts
except Exception:
    aipc_voice_tts = None
try:
    import aipc_voice_ux as voice_ux
except Exception:
    voice_ux = None
try:
    import aipc_voice_timing
except Exception:
    aipc_voice_timing = None

# Set once per mic-captured turn; show() marks play_start and flushes it.
_turn_timer = None

def _ux(state, detail="", **kw):
    if voice_ux is None:
        return
    try:
        voice_ux.announce(state, detail, **kw)
    except Exception:
        pass

STT_URL = os.environ.get("AIPC_VOICE_STT_URL", "http://127.0.0.1:9001/transcribe")
CHAT_URL = os.environ.get("AIPC_VOICE_CHAT_URL", "http://127.0.0.1:4100/chat")
RECORD_SECONDS = int(os.environ.get("AIPC_VOICE_RECORD_SECONDS", "5"))
MAX_SECONDS = int(os.environ.get("AIPC_VOICE_MAX_SECONDS", "20"))
VAD_DEFAULT = os.environ.get("AIPC_VOICE_VAD", "1") != "0"
VAD_ENERGY = float(os.environ.get("AIPC_VOICE_VAD_ENERGY", "1800"))
END_SILENCE_MS = int(os.environ.get("AIPC_VOICE_END_SILENCE_MS", "450"))
START_TIMEOUT_S = float(os.environ.get("AIPC_VOICE_START_TIMEOUT", "2.5"))
SAMPLE_RATE = 16000
FRAME_MS = 30
SESSION_ID = os.environ.get("AIPC_VOICE_SESSION_ID", "voice-assistant")
# Must be > AIPC_HERMES_VOICE_TIMEOUT (default 720) so Hermes returns an
# explicit timeout message instead of urllib hanging as a mystery failure.
# Long / background Hermes acks return fast; sync multi-step can run ~12 min.
CHAT_TIMEOUT = float(os.environ.get("AIPC_VOICE_CHAT_TIMEOUT", "780"))
# Closed loop default: direct orchestrator /chat (resident-small). Aggregator
# is optional (mode routing / online) — opt in with AIPC_VOICE_USE_AGGREGATOR=1.
# Default was 1 and double-failed (NPU+agent 502) before falling back to /chat.
USE_AGGREGATOR = os.environ.get("AIPC_VOICE_USE_AGGREGATOR", "0") == "1"



def _capture_env():
    env = os.environ.copy()
    try:
        from aipc_lib.voice_audio import capture_env, ensure_denoise_source
        ensure_denoise_source()
        return capture_env(env)
    except Exception:
        pass
    try:
        import voice_audio
        voice_audio.ensure_denoise_source()
        return voice_audio.capture_env(env)
    except Exception:
        pass
    env.setdefault("PULSE_SOURCE", "aipc_denoise_out.monitor")
    return env

def build_parser():
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument(
        "--seconds",
        type=int,
        default=None,
        help="with --no-vad: fixed duration; with VAD: max seconds "
        f"(default max={MAX_SECONDS}, fixed={RECORD_SECONDS})",
    )
    ap.add_argument(
        "--vad",
        action=argparse.BooleanOptionalAction,
        default=VAD_DEFAULT,
        help="end recording after silence (default: on; --no-vad = fixed length)",
    )
    ap.add_argument(
        "--end-silence-ms",
        type=int,
        default=END_SILENCE_MS,
        help="silence after speech that ends VAD capture (default 800)",
    )
    ap.add_argument(
        "--vad-energy",
        type=float,
        default=VAD_ENERGY,
        help="RMS threshold for speech vs silence (default 1800)",
    )
    ap.add_argument(
        "--wav",
        default=None,
        help="use existing WAV (skip mic record) — for wake pipeline handoff",
    )
    ap.add_argument(
        "--text",
        default=None,
        help="use this transcript (skip STT) — progressive STT from wake handoff",
    )
    ap.add_argument("--session-id", default=SESSION_ID, help="agent-orchestrator session id")
    ap.add_argument(
        "--self-test", action="store_true",
        help="run offline logic checks only (no mic/network) and exit; used by verify.sh",
    )
    return ap


def _rms(frame: bytes) -> float:
    if len(frame) < 2:
        return 0.0
    n = len(frame) // 2
    samples = array.array("h")
    samples.frombytes(frame[: n * 2])
    if not samples:
        return 0.0
    acc = 0
    for s in samples:
        acc += s * s
    return (acc / len(samples)) ** 0.5


def _write_wav(path: str, pcm: bytes, rate: int = SAMPLE_RATE) -> None:
    with wave.open(path, "wb") as w:
        w.setnchannels(1)
        w.setsampwidth(2)
        w.setframerate(rate)
        w.writeframes(pcm)


def record_wav(path, seconds):
    """Record fixed `seconds` of audio from the default ALSA input via arecord.

    16 kHz mono S16_LE — a common STT input format, matching the assumed
    voice-stt-sensevoice contract above.
    """
    subprocess.run(
        ["arecord", "-f", "S16_LE", "-r", "16000", "-c", "1", "-d", str(seconds), path],
        check=True,
        capture_output=True,
        env=_capture_env(),
    )


def record_wav_vad(
    path: str,
    *,
    max_seconds: int = MAX_SECONDS,
    energy: float = VAD_ENERGY,
    end_silence_ms: int = END_SILENCE_MS,
    start_timeout_s: float = START_TIMEOUT_S,
) -> dict:
    """Record until end-of-speech (silence after speech) or max_seconds."""
    frame_bytes = SAMPLE_RATE * FRAME_MS // 1000 * 2
    end_need = max(1, end_silence_ms // FRAME_MS)
    preroll_n = max(1, 300 // FRAME_MS)
    max_frames = max(1, int(max_seconds * 1000 // FRAME_MS))

    proc = subprocess.Popen(
        [
            "arecord",
            "-f",
            "S16_LE",
            "-r",
            str(SAMPLE_RATE),
            "-c",
            "1",
            "-t",
            "raw",
            "-q",
            "-",
        ],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=_capture_env(),
    )
    assert proc.stdout is not None
    pcm = bytearray()
    preroll: list[bytes] = []
    speech = False
    silent_run = 0
    speech_run = 0
    frames = 0
    t0 = time.monotonic()
    reason = "max"
    try:
        while frames < max_frames:
            data = proc.stdout.read(frame_bytes)
            if not data:
                reason = "eof"
                break
            if len(data) < frame_bytes:
                data = data + b"\x00" * (frame_bytes - len(data))
            frames += 1
            rms = _rms(data)
            loud = rms >= energy

            if not speech:
                preroll.append(data)
                if len(preroll) > preroll_n:
                    preroll.pop(0)
                if loud:
                    speech_run += 1
                else:
                    speech_run = 0
                if speech_run >= 3:
                    speech = True
                    for f in preroll:
                        pcm.extend(f)
                    preroll.clear()
                    silent_run = 0
                elif (time.monotonic() - t0) >= start_timeout_s:
                    reason = "no_speech"
                    break
                continue

            pcm.extend(data)
            if loud:
                silent_run = 0
            else:
                silent_run += 1
                if silent_run >= end_need:
                    reason = "end_silence"
                    break
    finally:
        proc.terminate()
        try:
            proc.wait(timeout=2)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait(timeout=1)

    if not speech and preroll:
        for f in preroll:
            pcm.extend(f)

    if not pcm:
        raise RuntimeError("arecord produced no audio")

    _write_wav(path, bytes(pcm))
    duration_s = len(pcm) / 2 / SAMPLE_RATE
    return {
        "speech_detected": speech,
        "duration_s": duration_s,
        "reason": reason,
        "energy": energy,
        "end_silence_ms": end_silence_ms,
    }


def _parse_text_field(raw: bytes) -> str:
    """Extract `text` from a JSON response body — shared by transcribe() and
    chat() since both contracts return {"text": "..."}."""
    return json.loads(raw)["text"]


def transcribe(wav_path):
    with open(wav_path, "rb") as f:
        data = f.read()
    url = STT_URL
    lang = os.environ.get("AIPC_VOICE_STT_LANG", "zh")
    if lang and "language=" not in url:
        url = f"{url}{'&' if '?' in url else '?'}language={lang}"
    req = urllib.request.Request(
        url, data=data, method="POST", headers={"Content-Type": "audio/wav"}
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return _parse_text_field(resp.read())


def _is_timeout_exc(exc: BaseException) -> bool:
    """True for bare TimeoutError and urllib.urlopen timeouts (URLError(reason=TimeoutError))."""
    if isinstance(exc, TimeoutError):
        return True
    try:
        import socket

        if isinstance(exc, socket.timeout):
            return True
    except Exception:
        pass
    if isinstance(exc, urllib.error.URLError):
        reason = getattr(exc, "reason", None)
        if isinstance(reason, TimeoutError):
            return True
        try:
            import socket

            if isinstance(reason, socket.timeout):
                return True
        except Exception:
            pass
        r = str(reason or exc).lower()
        if "timed out" in r or "timeout" in r:
            return True
    if isinstance(exc, OSError) and "timed out" in str(exc).lower():
        return True
    return False


def _chat_timeout_text() -> str:
    return f"处理超时了（超过 {CHAT_TIMEOUT:.0f} 秒），请简化问题后再试。"


def chat(text, session_id):
    """Return (reply_text, end_session, expect_reply, background, session_id).

    end_session → wake should dismiss + hide, no follow-up (farewell).
    expect_reply → assistant is asking the user something; wake should open
    a short follow-up window. background → turn detached to a background job
    (auto-detach past DETACH_S, or explicit long mode); mic frees like a done
    turn (no follow-up) but the overlay shows a persistent pending pill.
    Default (all false) → answered, no follow-up.
    """
    payload = json.dumps(
        {"text": text, "session_id": session_id, "source": "voice"}
    ).encode()
    req = urllib.request.Request(
        CHAT_URL, data=payload, method="POST", headers={"Content-Type": "application/json"}
    )
    try:
        with urllib.request.urlopen(req, timeout=CHAT_TIMEOUT) as resp:
            body = resp.read()
    except TimeoutError:
        return _chat_timeout_text(), False, False, False, session_id
    except urllib.error.HTTPError as exc:
        try:
            raw = exc.read()
            data = json.loads(raw.decode(errors="replace"))
            if isinstance(data, dict) and data.get("text"):
                return (
                    str(data["text"]),
                    bool(data.get("end_session")),
                    bool(data.get("expect_reply")),
                    bool(data.get("background")),
                    str(data.get("session_id") or session_id),
                )
            if isinstance(data, dict) and data.get("error"):
                msg = data["error"]
                if isinstance(msg, dict):
                    msg = msg.get("message") or msg
                return f"助手暂时无法完成：{msg}", False, False, False, session_id
        except Exception:
            pass
        raise
    except urllib.error.URLError as exc:
        if _is_timeout_exc(exc):
            return _chat_timeout_text(), False, False, False, session_id
        raise
    data = json.loads(body.decode() or "{}")
    if isinstance(data, dict):
        # Prefer full text for HUD; spoken_summary is for TTS only (single owner)
        full = str(data.get("text") or "")
        spoken = str(data.get("spoken_summary") or "").strip()
        # stash for show() via attribute on str? return full; speak uses spoken if set
        chat._last_spoken = spoken  # type: ignore[attr-defined]
        return (
            full,
            bool(data.get("end_session")),
            bool(data.get("expect_reply")),
            bool(data.get("background")),
            str(data.get("session_id") or session_id),
        )
    return str(data), False, False, False, session_id


def _turn_rc(end_session: bool, expect_reply: bool, background: bool = False) -> int:
    """Map turn-completion signals to the voice-wake return code.

    2 = farewell → dismiss, no follow-up (unchanged behavior).
    4 = turn detached to a background job (auto-detach past DETACH_S, or
        explicit long mode) → mic frees (no follow-up window, same as the
        default done case) but the overlay shows a persistent pending pill
        instead of a "done" card, until the background completion notify
        replaces it.
    3 = assistant is asking the user something → open a short follow-up window.
    0 = default: answered, not expecting a reply → no follow-up (the fix for
        "讲完话还一直听" — previously every non-farewell answer opened one).

    Precedence: end_session always wins (farewell overrides everything else).
    background beats expect_reply — a detached long turn already frees the
    mic; there is no clarify question left to answer with a follow-up window.
    """
    if end_session:
        return 2
    if background:
        return 4
    if expect_reply:
        return 3
    return 0



def chat_via_aggregator(text, session_id):
    """Route through aipc-assistant (text+mode+online/local). Returns reply text."""
    aipc_assistant = shutil.which("aipc-assistant")
    if not aipc_assistant:
        # Dev: module tree next to voice-pipecat
        cand = Path(__file__).resolve().parents[3] / "assistant-aggregator/files/usr/bin/aipc-assistant"
        if not cand.is_file():
            cand = Path("/var/home/birdyo/aipc-strix-halo/modules/assistant-aggregator/files/usr/bin/aipc-assistant")
        aipc_assistant = str(cand) if cand.is_file() else None
    if not aipc_assistant:
        raise FileNotFoundError("aipc-assistant not found")

    env = os.environ.copy()
    # Ensure aggregator package is importable when running from module tree
    lib = Path(aipc_assistant).resolve().parent.parent / "lib"
    if lib.is_dir():
        env["PYTHONPATH"] = f"{lib}{os.pathsep}{env.get('PYTHONPATH', '')}"
    etc = Path("/etc/aipc/assistant")
    mod_etc = Path(aipc_assistant).resolve().parents[2] / "etc/aipc/assistant"
    if not etc.is_dir() and mod_etc.is_dir():
        env["AIPC_ASSISTANT_ETC"] = str(mod_etc)

    proc = subprocess.run(
        [
            sys.executable,
            aipc_assistant,
            "--text",
            text,
            "--modality",
            "voice",
            "--session-id",
            session_id,
            "--json",
        ],
        capture_output=True,
        text=True,
        timeout=CHAT_TIMEOUT,
        env=env,
        check=False,
    )
    out = (proc.stdout or "").strip()
    if proc.returncode != 0:
        err = (proc.stderr or out or "aggregator failed").strip()
        raise RuntimeError(err)
    try:
        data = json.loads(out)
        if data.get("error"):
            raise RuntimeError(str(data["error"]))
        return str(data.get("text") or "")
    except json.JSONDecodeError:
        return out


def _overlay_active() -> bool:
    if voice_ux is None:
        return False
    try:
        st, ok = voice_ux.overlay_status()
        return bool(ok or st == "active")
    except Exception:
        return False


def _reply_notify(title: str, body: str, *, timeout_ms: int = 5000) -> None:
    """Rare native bubble — overlay owns normal UX."""
    if not shutil.which("notify-send"):
        return
    try:
        subprocess.run(
            [
                "notify-send",
                "--app-name=AIPC Voice",
                "--urgency=low",
                f"--expire-time={timeout_ms}",
                "--transient",
                "--hint=string:x-canonical-private-synchronous:aipc-voice-reply",
                title,
                (body or "")[:240],
            ],
            check=False,
            timeout=2,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass


def _long_wait_watchdog(detail: str = "", delay_s: float | None = None):
    """Periodic low-urgency notify while LLM/Hermes still running (long tasks).

    First ping after delay_s (default 8s), then every interval_s (default 45s).
    """
    # Agent/Hermes already drives the glass HUD. This watchdog only helps when
    # the agent is silent for a long time — never flash every few seconds.
    if delay_s is None:
        delay_s = float(os.environ.get("AIPC_VOICE_LONG_WAIT_S", "20"))
    try:
        interval_s = float(os.environ.get("AIPC_VOICE_LONG_WAIT_INTERVAL_S", "90"))
    except ValueError:
        interval_s = 90.0
    if delay_s <= 0 or os.environ.get("AIPC_VOICE_UX_NOTIFY", "auto") in (
        "0",
        "off",
        "false",
        "no",
    ):
        class _Nop:
            def cancel(self) -> None:
                return None

        return _Nop()
    done = threading.Event()
    t0 = time.monotonic()

    def _run() -> None:
        if done.wait(delay_s):
            return
        n = 0
        while not done.is_set():
            n += 1
            elapsed = time.monotonic() - t0
            body = (detail or "仍在處理，請稍候…")[:80]
            body = f"{body} · {elapsed:.0f}s"
            # Prefer overlay only; skip native bubble when HUD is up
            if not _overlay_active():
                _reply_notify("AIPC · 還在處理", body, timeout_ms=4000)
            print(
                f"aipc-voice-once: long-wait #{n} after {elapsed:.0f}s",
                file=sys.stderr,
            )
            # Soft update — do not force=True (fights agent working state)
            _ux("working", body[:80])
            if interval_s <= 0 or done.wait(interval_s):
                return

    threading.Thread(target=_run, name="aipc-long-wait", daemon=True).start()

    class _Watch:
        def cancel(self) -> None:
            done.set()

    return _Watch()


def _answer_for_overlay(reply: str) -> str:
    """Keep full answer + media list for HUD (not speech-length cut)."""
    s = (reply or "").strip()
    if not s:
        return "完成"
    try:
        lim = int(os.environ.get("AIPC_OVERLAY_BODY_CHARS", "2500"))
    except ValueError:
        lim = 2500
    if len(s) <= lim:
        return s
    # Prefer keeping a trailing media block when truncating
    media_i = s.find("（相關媒體）")
    if media_i < 0:
        media_i = s.find("(相關媒體)")
    if media_i > 0 and media_i < lim:
        head = s[:media_i].rstrip()
        media = s[media_i:]
        budget = max(200, lim - len(media) - 8)
        if len(head) > budget:
            head = head[: budget - 1] + "…"
        return (head + "\n\n" + media)[: lim + 200]
    return s[: lim - 1] + "…"


def show(reply):
    """Show full answer on HUD first, then best-effort TTS (never block on done).

    Voice-once is the sole TTS owner for voice sessions — agent must not speak.
    """
    global _turn_timer
    body = _answer_for_overlay(reply)
    cue = "\n\n（不对？说「不对」可反馈）"
    if "不对" in body or "不對" in body:
        done_body = body
    else:
        done_body = body + cue
        try:
            lim = int(os.environ.get("AIPC_OVERLAY_BODY_CHARS", "2500"))
        except ValueError:
            lim = 2500
        if len(done_body) > lim + 80:
            done_body = body[: lim - 1] + "…" + cue
    try:
        hold = float(os.environ.get("AIPC_VOICE_DONE_HOLD_S", "75"))
    except ValueError:
        hold = 75.0
    # CRITICAL: paint done BEFORE TTS. If speak hangs, user still sees the answer.
    try:
        _ux("done", done_body, force=True, ttl_s=hold)
    except TypeError:
        _ux("done", done_body, force=True)

    # Batch play_start proxy: the moment we begin speaking. capture_end→here is
    # the dead-air the user feels (STT + intent + LLM + prep). Best-effort only.
    if _turn_timer is not None:
        try:
            _turn_timer.mark("play_start")
        except Exception:
            pass

    spoke = False
    if os.environ.get("AIPC_VOICE_TTS", "1") == "0":
        print("aipc-voice-once: TTS skipped (AIPC_VOICE_TTS=0)", file=sys.stderr)
    elif aipc_voice_tts is None:
        print(
            "aipc-voice-once: TTS module missing "
            "(need aipc_voice_tts under /var/lib/aipc-voice/lib or /usr/lib/aipc-voice)",
            file=sys.stderr,
        )
    else:
        try:
            # CosyVoice CPU often needs 40–90s; 35s made long CJK replies silent.
            tts_wall = float(os.environ.get("AIPC_VOICE_TTS_TIMEOUT_S", "90"))
        except ValueError:
            tts_wall = 90.0
        # Prefer server spoken_summary; never use TTS length to drop full HUD body
        spoken = ""
        try:
            spoken = str(getattr(chat, "_last_spoken", "") or "").strip()
        except Exception:
            spoken = ""
        speech = spoken or compress_for_speech(reply)
        try:
            import concurrent.futures

            # Stop any orphan aipc-tts before we own the speakers
            try:
                if hasattr(aipc_voice_tts, "stop_active_tts"):
                    aipc_voice_tts.stop_active_tts()
            except Exception:
                pass

            def _speak_once() -> bool:
                return bool(aipc_voice_tts.speak(speech))

            def _speak_kokoro_fallback() -> bool:
                # Fast path when CosyVoice hangs / exceeds wall clock.
                prev = os.environ.get("AIPC_PREFER_COSYVOICE")
                os.environ["AIPC_PREFER_COSYVOICE"] = "0"
                try:
                    try:
                        if hasattr(aipc_voice_tts, "stop_active_tts"):
                            aipc_voice_tts.stop_active_tts()
                    except Exception:
                        pass
                    return bool(aipc_voice_tts.speak(speech))
                finally:
                    if prev is None:
                        os.environ.pop("AIPC_PREFER_COSYVOICE", None)
                    else:
                        os.environ["AIPC_PREFER_COSYVOICE"] = prev

            with concurrent.futures.ThreadPoolExecutor(max_workers=1) as pool:
                fut = pool.submit(_speak_once)
                try:
                    spoke = bool(fut.result(timeout=max(5.0, tts_wall)))
                except concurrent.futures.TimeoutError:
                    print(
                        f"aipc-voice-once: TTS timeout after {tts_wall:.0f}s "
                        "— falling back to Kokoro",
                        file=sys.stderr,
                    )
                    try:
                        if hasattr(aipc_voice_tts, "stop_active_tts"):
                            aipc_voice_tts.stop_active_tts()
                    except Exception:
                        pass
                    try:
                        spoke = bool(_speak_kokoro_fallback())
                    except Exception as exc2:  # noqa: BLE001
                        print(
                            f"aipc-voice-once: Kokoro fallback error: {exc2}",
                            file=sys.stderr,
                        )
                        spoke = False
        except Exception as exc:  # noqa: BLE001 — never fail the round trip on TTS
            print(f"aipc-voice-once: TTS error: {exc}", file=sys.stderr)
    if spoke:
        print("aipc-voice-once: spoke reply via TTS")
    else:
        print("aipc-voice-once: TTS did not play (text-only this turn)", file=sys.stderr)
    # Re-assert done after TTS so a mid-speak UX write cannot leave 回答中 forever
    try:
        _ux("done", done_body, force=True, ttl_s=hold)
    except TypeError:
        _ux("done", done_body, force=True)
    # Default: no desktop bubble (overlay is the HUD). Notify only when:
    # - AIPC_VOICE_REPLY_NOTIFY=1/force, or
    # - TTS failed AND overlay is not running (user would otherwise see nothing).
    mode = (os.environ.get("AIPC_VOICE_REPLY_NOTIFY") or "auto").strip().lower()
    if mode in ("1", "on", "true", "yes", "force", "always"):
        _reply_notify("AIPC Assistant", reply or "", timeout_ms=15000)
    elif mode not in ("0", "off", "false", "no") and not spoke and not _overlay_active():
        _reply_notify("AIPC Assistant", reply or "", timeout_ms=15000)
    elif not spoke and not _overlay_active():
        print(f"aipc-voice-once: reply (no TTS/overlay): {reply}")

    # One record per mic-captured turn; best-effort, never affects the turn.
    if _turn_timer is not None:
        try:
            _turn_timer.flush()
        except Exception:
            pass
        _turn_timer = None


def _matches_open_portal(text: str) -> bool:
    """Local keyword intent — open AIPC portal/dashboard without LLM.

    Must tolerate STT slurs (e.g. 'dashashboard') so we never fall through
    to aggregator/chat for this action.
    """
    # Prefer shared implementation when tools package is available.
    try:
        from aipc_lib.portal import matches_open_portal_intent

        return matches_open_portal_intent(text)
    except Exception:
        pass
    import difflib
    import re

    raw = (text or "").strip().lower()
    for ch in "。.!！?？,，、；;:：\"'“”‘’":
        raw = raw.replace(ch, "")
    compact = "".join(raw.split())
    nouns = (
        "dashboard", "portal", "仪表板", "儀表板", "管理界面", "管理介面",
        "控制台", "面板", "首页", "首頁",
    )
    verbs = ("open", "show", "launch", "打开", "打開", "开启", "開啟", "显示", "顯示")
    if compact in {
        "dashboard", "portal", "打开dashboard", "打開dashboard",
        "打开portal", "打開portal", "opendashboard", "openportal",
        "打开面板", "打開面板",
    }:
        return True
    has_noun = any(n in raw or n in compact for n in nouns)
    if not has_noun and "dash" in compact and "board" in compact:
        has_noun = True
    if not has_noun:
        for tok in re.findall(r"[a-z]+", compact):
            if difflib.SequenceMatcher(None, tok, "dashboard").ratio() >= 0.72:
                has_noun = True
                break
            if difflib.SequenceMatcher(None, tok, "portal").ratio() >= 0.85:
                has_noun = True
                break
    has_verb = any(v in raw or v in compact for v in verbs)
    return bool(has_noun and (has_verb or len(compact) <= 24))


def _open_portal_local() -> str:
    """Ensure portal is up and open a browser; return spoken/notify reply."""
    aipc = shutil.which("aipc")
    if aipc:
        try:
            proc = subprocess.run(
                [aipc, "portal", "open"],
                capture_output=True,
                text=True,
                timeout=20,
                check=False,
            )
            out = (proc.stdout or proc.stderr or "").strip()
            if proc.returncode == 0:
                return out or "已打开 AIPC 管理面板。"
            return out or "打开 AIPC 管理面板失败。"
        except Exception as exc:  # noqa: BLE001
            return f"打开面板失败：{exc}"
    # Fallback without aipc CLI: hit default URL after best-effort xdg-open.
    url = os.environ.get("AIPC_PORTAL_URL", "http://127.0.0.1:7080/")
    try:
        env = os.environ.copy()
        env.setdefault("DISPLAY", ":0")
        if shutil.which("xdg-open"):
            subprocess.run(["xdg-open", url], env=env, check=False, timeout=10)
        return f"已尝试打开 {url}"
    except Exception as exc:  # noqa: BLE001
        return f"打开面板失败：{exc}"


def _self_test():
    """Offline checks: no mic, no network. Exercises the parts that don't
    need live hardware/services so verify.sh has something real to run."""
    assert STT_URL.startswith("http://127.0.0.1:9001")
    assert CHAT_URL.startswith("http://127.0.0.1:4100")
    assert _parse_text_field(b'{"text": "hello"}') == "hello"
    ns = build_parser().parse_args(["--seconds", "3", "--no-vad"])
    assert ns.seconds == 3
    assert ns.vad is False
    ns2 = build_parser().parse_args([])
    assert ns2.vad is True
    # synthetic PCM: loud then silence → end_silence path (no mic)
    assert _rms(b"\x00\x00" * 160) == 0.0
    loud = array.array("h", [8000] * 480).tobytes()
    assert _rms(loud) > 1000
    assert os.environ.get("AIPC_VOICE_TTS", "1") in ("0", "1")
    # Closed-loop product default: direct /chat, aggregator opt-in only.
    assert os.environ.get("AIPC_VOICE_USE_AGGREGATOR", "0") != "1" or USE_AGGREGATOR is True
    assert USE_AGGREGATOR is False or os.environ.get("AIPC_VOICE_USE_AGGREGATOR") == "1"
    if "AIPC_VOICE_USE_AGGREGATOR" not in os.environ:
        assert USE_AGGREGATOR is False
    assert callable(chat_via_aggregator)
    assert _matches_open_portal("打开 dashboard")
    assert _matches_open_portal("打开 dashashboard。")  # real STT slip
    assert _matches_open_portal("open portal")
    assert _matches_open_portal("打開管理介面")
    assert not _matches_open_portal("今天天气怎么样")
    assert not usable_transcript("。")
    assert not usable_transcript("我")
    assert usable_transcript("今天天气如何")
    assert len(compress_for_speech("第一句。第二句。第三句很长" * 5)) <= 85
    # --text without --wav must not require mic (closed-loop text gate)
    ns_text = build_parser().parse_args(["--text", "你好"])
    assert ns_text.text == "你好" and ns_text.wav is None
    print("aipc-voice-once: self-test OK")
    return 0



def usable_transcript(text: str) -> bool:
    """Reject STT noise that would waste a LLM turn and confuse the user."""
    if not text:
        return False
    s = text.strip()
    # drop emoji for length check
    s2 = re.sub(r"[\U0001F300-\U0001FAFF\U00002700-\U000027BF]+", "", s)
    s2 = re.sub(r"[\s\W_]+", "", s2, flags=re.UNICODE)
    if len(s2) < 2:
        return False
    # pure punctuation / single particle
    if s2 in ("我", "嗯", "啊", "呃", "哦", "喔", "呀", "的", "了", "吗", "呢"):
        return False
    return True


def compress_for_speech(text: str, max_chars: int = 160) -> str:
    """Keep TTS speakable; prefer sentence ends (was 80 → cut mid Hermes answer)."""
    if not text:
        return ""
    try:
        max_chars = int(os.environ.get("AIPC_VOICE_TTS_CHARS", str(max_chars)))
    except ValueError:
        pass
    s = re.sub(r"[`*_#>]+", "", text)
    s = re.sub(r"\s+", " ", s).strip()
    # Prefer first 1–2 sentences
    parts = re.split(r"(?<=[。！？.!?])\s*", s)
    parts = [p for p in parts if p.strip()]
    out = ""
    for p in parts[:3]:
        if len(out) + len(p) > max_chars and out:
            break
        out = (out + p).strip()
    if not out:
        out = s
    if len(out) > max_chars:
        cut = out[: max_chars - 1]
        for sep in ("。", "！", "？", ".", "!", "?", "，", ","):
            i = cut.rfind(sep)
            if i >= max(20, max_chars // 3):
                return cut[: i + 1]
        out = cut.rstrip("，,、;； ") + "。"
    return out


def unclear_prompt() -> str:
    return "没听清楚，请再说一次。"

def main(argv=None):
    args = build_parser().parse_args(argv)
    if args.self_test:
        return _self_test()

    unlink_wav = False
    wav_path = None
    # --text alone: skip mic (closed-loop text/WAV gate; wake still uses --wav).
    text_only = args.text is not None and str(args.text).strip() and not args.wav
    if args.wav:
        wav_path = args.wav
        if not Path(wav_path).is_file():
            print(f"aipc-voice-once: --wav not found: {wav_path}", file=sys.stderr)
            return 1
        print(f"aipc-voice-once: using provided wav {wav_path}", flush=True)
        _ux("thinking", "處理指令", force=True)
    elif text_only:
        print("aipc-voice-once: --text without --wav; skip mic", flush=True)
        _ux("thinking", "處理指令", force=True)
    else:
        if not shutil.which("arecord"):
            print("aipc-voice-once: arecord not found (alsa-utils not installed)", file=sys.stderr)
            return 1
        fd, wav_path = tempfile.mkstemp(suffix=".wav", prefix="aipc-voice-")
        os.close(fd)
        unlink_wav = True
        try:
            if args.vad:
                max_s = args.seconds if args.seconds is not None else MAX_SECONDS
                print(
                    f"aipc-voice-once: recording until silence "
                    f"(max {max_s}s, end_silence={args.end_silence_ms}ms)...",
                    flush=True,
                )
                _ux("recording", force=True)
                stats = record_wav_vad(
                    wav_path,
                    max_seconds=max_s,
                    energy=args.vad_energy,
                    end_silence_ms=args.end_silence_ms,
                )
                print(
                    f"aipc-voice-once: captured {stats['duration_s']:.2f}s "
                    f"reason={stats['reason']} speech={stats['speech_detected']}",
                    flush=True,
                )
                if not stats["speech_detected"]:
                    print("aipc-voice-once: no speech detected", file=sys.stderr)
                    return 1
            else:
                secs = args.seconds if args.seconds is not None else RECORD_SECONDS
                print(f"aipc-voice-once: recording {secs}s (fixed)...")
                record_wav(wav_path, secs)
        except subprocess.CalledProcessError as exc:
            err = (exc.stderr or b"").decode(errors="replace")
            print(f"aipc-voice-once: arecord failed: {err}", file=sys.stderr)
            if unlink_wav:
                try:
                    os.unlink(wav_path)
                except OSError:
                    pass
            return 1
        except RuntimeError as exc:
            print(f"aipc-voice-once: record failed: {exc}", file=sys.stderr)
            if unlink_wav:
                try:
                    os.unlink(wav_path)
                except OSError:
                    pass
            return 1

    # Instrument only real mic-captured turns (unlink_wav ⇒ we recorded from
    # the mic). --wav/--text handoff paths have no user end-of-speech to time.
    global _turn_timer
    _turn_timer = None
    if unlink_wav and aipc_voice_timing is not None:
        try:
            _turn_timer = aipc_voice_timing.TurnTimer(path="batch")
            _turn_timer.mark("capture_end")
        except Exception:
            _turn_timer = None

    try:
        _ux("thinking", force=True)
        if args.text is not None and str(args.text).strip():
            text = str(args.text).strip()
            print(f"aipc-voice-once: using progressive text: {text}", flush=True)
        else:
            try:
                text = transcribe(wav_path)
            except (urllib.error.URLError, OSError) as exc:
                print(f"aipc-voice-once: STT service unreachable at {STT_URL}: {exc}", file=sys.stderr)
                return 1
        print(f"aipc-voice-once: you said: {text}")
        _ux("thinking", (text or "")[:40], force=True)

        if not usable_transcript(text):
            reply = unclear_prompt()
            print(f"aipc-voice-once: unusable transcript → {reply}", flush=True)
            _ux("no_speech", text or "", force=True)
            show(reply)
            _ux("done", force=True)
            return 0

        # Local intents run here (DISPLAY/Pulse session preserved); skip LLM.
        try:
            from aipc_lib.voice_intents import resolve_intent

            hit = resolve_intent(text)
        except Exception:
            hit = None
            if _matches_open_portal(text):
                reply = _open_portal_local()
                print(f"aipc-voice-once: local-intent open-portal → {reply}")
                show(reply)
                return 0
        if hit is not None:
            reply = hit.reply
            print(f"aipc-voice-once: local-intent {hit.name} → {reply}")
            show(reply)
            _ux("done", hit.name, force=True)
            return 0

        # Visible progress while orchestrator / tools / Hermes run
        _ux("thinking", (text or "處理中")[:40], force=True)
        wait = _long_wait_watchdog((text or "")[:60])
        end_session = False
        expect_reply = False
        background = False
        try:
            if USE_AGGREGATOR:
                try:
                    reply = chat_via_aggregator(text, args.session_id); end_session = False
                    print("aipc-voice-once: via aggregator")
                except (FileNotFoundError, RuntimeError, subprocess.TimeoutExpired) as exc:
                    print(
                        f"aipc-voice-once: aggregator unavailable ({exc}); "
                        f"falling back to direct /chat",
                        file=sys.stderr,
                    )
                    reply, end_session, expect_reply, background, _sid = chat(
                        text, args.session_id
                    )
            else:
                reply, end_session, expect_reply, background, _sid = chat(
                    text, args.session_id
                )
        except (urllib.error.URLError, OSError, TimeoutError) as exc:
            # chat() already maps urlopen timeouts → spoken text; if anything
            # still surfaces here, speak timeout instead of silent exit 1.
            if _is_timeout_exc(exc):
                reply = _chat_timeout_text()
            else:
                print(
                    f"aipc-voice-once: agent-orchestrator unreachable at {CHAT_URL}: {exc}",
                    file=sys.stderr,
                )
                return 1
        finally:
            wait.cancel()
    finally:
        if unlink_wav:
            try:
                os.unlink(wav_path)
            except OSError:
                pass

    print(f"aipc-voice-once: assistant: {reply}")
    if end_session:
        print("aipc-voice-once: session complete", flush=True)
    show(reply)
    # rc contract (see _turn_rc): 2 = farewell, dismiss + hide overlay;
    # 4 = turn detached to background, mic frees but overlay keeps a pending
    # pill; 3 = assistant expects a reply, wake opens a short follow-up
    # window; 0 = answered/done, no follow-up (default — fixes "讲完话还一直听").
    rc = _turn_rc(end_session, expect_reply, background)
    if rc == 2:
        print("aipc-voice-once: end_session → dismiss multi-turn", flush=True)
        # Keep farewell text; do not blank the card
        _ux("done", _answer_for_overlay(reply or "会话结束"), force=True)
        return rc
    if rc == 4:
        # show() already spoke the ack via TTS and painted a "done" card;
        # replace it with the persistent background-pending pill (mic is
        # free, no follow-up window — same as rc==0's no-follow-up case).
        print("aipc-voice-once: background detach → pending pill, mic free", flush=True)
        _ux("bg_task", _answer_for_overlay(reply or "背景任务进行中"), force=True)
        return rc
    if rc == 3:
        print("aipc-voice-once: expect_reply → open short follow-up", flush=True)
    # show() already set done with full answer + feedback cue. Do NOT
    # blank-overwrite with _ux("done") — that made the panel vanish in ~4s
    # and blocked「不对」feedback.
    return rc


if __name__ == "__main__":
    sys.exit(main())
