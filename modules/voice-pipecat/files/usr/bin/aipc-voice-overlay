#!/usr/bin/env python3
"""Launch the Siri-like AIPC voice overlay (user session)."""
from __future__ import annotations

import sys
from pathlib import Path

for _p in (
    Path("/usr/lib/aipc-voice"),
    Path("/var/lib/aipc-voice/lib"),
    Path.home() / ".local/lib/aipc-voice",
    Path(__file__).resolve().parents[1] / "lib/aipc-voice",
):
    if _p.is_dir():
        sys.path.insert(0, str(_p))

from aipc_voice_overlay import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
