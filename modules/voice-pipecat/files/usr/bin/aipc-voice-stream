#!/usr/bin/env python3
"""Streaming voice turn worker (openspec: voice-streaming-turn).

Pipeline (no second mic — wake owns capture):
  --wav → SenseVoice final STT → local intents → POST /chat/stream
  → sentence-chunk TTS queue → play

On any stream stage failure: log stream_fallback and invoke batch
aipc-voice-once --wav (same turn). Default off for wake until
AIPC_VOICE_STREAM=1 (hardware-gated).
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.request
from pathlib import Path

for _p in (
    Path("/usr/lib/aipc-voice"),
    Path("/var/lib/aipc-voice/lib"),
    Path.home() / ".local/lib/aipc-voice",
    Path(__file__).resolve().parents[1] / "lib/aipc-voice",
):
    if _p.is_dir():
        sys.path.insert(0, str(_p))

try:
    import aipc_voice_stream as stream_mod
except Exception:
    stream_mod = None
try:
    import aipc_voice_tts as tts_mod
except Exception:
    tts_mod = None
try:
    import aipc_voice_ux as voice_ux
except Exception:
    voice_ux = None
try:
    import aipc_voice_timing
except Exception:
    aipc_voice_timing = None

STT_URL = os.environ.get("AIPC_VOICE_STT_URL", "http://127.0.0.1:9001/transcribe")
CHAT_STREAM_URL = os.environ.get(
    "AIPC_VOICE_CHAT_STREAM_URL", "http://127.0.0.1:4100/chat/stream"
)
SESSION_ID = os.environ.get("AIPC_VOICE_SESSION_ID", "voice-stream")
ONCE_CMD = os.environ.get("AIPC_VOICE_ONCE", "/usr/bin/aipc-voice-once")
STT_TIMEOUT = float(os.environ.get("AIPC_VOICE_STT_TIMEOUT", "30"))


def _ux(state: str, detail: str = "", **kw) -> None:
    if voice_ux is None:
        return
    try:
        voice_ux.announce(state, detail, **kw)
    except Exception:
        pass


def build_parser() -> argparse.ArgumentParser:
    ap = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    ap.add_argument("--wav", required=False, help="command WAV from wake (no mic)")
    ap.add_argument(
        "--text",
        default=None,
        help="skip STT; use this transcript (progressive handoff)",
    )
    ap.add_argument("--session-id", default=SESSION_ID)
    ap.add_argument(
        "--no-fallback",
        action="store_true",
        help="do not fall back to aipc-voice-once on stream failure",
    )
    ap.add_argument(
        "--self-test",
        action="store_true",
        help="offline checks only (verify.sh)",
    )
    return ap


def _parse_text_field(body: bytes) -> str:
    try:
        obj = json.loads(body.decode("utf-8", errors="replace"))
    except json.JSONDecodeError:
        return ""
    if isinstance(obj, dict):
        return str(obj.get("text") or "").strip()
    return ""


def stt_wav(path: str, opener=urllib.request.urlopen) -> str:
    with open(path, "rb") as f:
        data = f.read()
    req = urllib.request.Request(
        STT_URL,
        data=data,
        headers={"Content-Type": "audio/wav"},
        method="POST",
    )
    with opener(req, timeout=STT_TIMEOUT) as resp:
        return _parse_text_field(resp.read())


def _usable(text: str) -> bool:
    # Prefer shared once logic if available via path import of voice-once helpers.
    s = (text or "").strip()
    if len(s) < 2:
        return False
    compact = "".join(ch for ch in s if ch.isalnum() or "\u4e00" <= ch <= "\u9fff")
    return len(compact) >= 2


def _local_intent(text: str) -> str | None:
    try:
        from aipc_lib import voice_intents

        handled, reply = voice_intents.try_handle(text)
        if handled:
            return reply or ""
    except Exception:
        pass
    try:
        from aipc_lib.portal import matches_open_portal_intent

        if matches_open_portal_intent(text):
            aipc = shutil.which("aipc")
            if aipc:
                subprocess.run(
                    [aipc, "portal", "open"],
                    capture_output=True,
                    timeout=20,
                    check=False,
                )
            return "已打开 AIPC 管理面板。"
    except Exception:
        pass
    return None


def fallback_once(wav_path: str | None, text: str | None, session_id: str) -> int:
    print("aipc-voice-stream: stream_fallback → aipc-voice-once", file=sys.stderr, flush=True)
    cmd = ONCE_CMD
    if not Path(cmd).is_file():
        which = shutil.which("aipc-voice-once")
        if which:
            cmd = which
    if not Path(cmd).is_file() and not shutil.which(cmd):
        print("aipc-voice-stream: once helper missing", file=sys.stderr)
        return 1
    argv = [cmd]
    if wav_path and Path(wav_path).is_file():
        argv.extend(["--wav", wav_path])
    if text and text.strip():
        argv.extend(["--text", text.strip()])
    argv.extend(["--session-id", session_id])
    try:
        return subprocess.call(argv)
    except OSError as exc:
        print(f"aipc-voice-stream: once spawn failed: {exc}", file=sys.stderr)
        return 1


def run_stream_turn(
    *,
    text: str,
    session_id: str,
    speak=None,
    stream_events=None,
    timer=None,
) -> tuple[bool, str]:
    """Drive SSE → sentence TTS. Returns (ok, full_reply_or_error)."""
    if stream_mod is None:
        return False, "aipc_voice_stream module missing"

    full_parts: list[str] = []
    buffer = ""
    saw_done = False
    error_msg = ""
    first_play_t: list[float] = []  # wall clock of first audible chunk

    def _mark(stage: str) -> None:
        if timer is not None:
            try:
                timer.mark_once(stage)
            except Exception:
                pass

    def _speak(t: str) -> bool:
        # First real chunk about to play → first audible sound of the turn.
        if not first_play_t:
            first_play_t.append(time.monotonic())
        _mark("play_start")
        _mark("tts_first_audio")
        if speak is not None:
            return bool(speak(t))
        if tts_mod is None:
            return False
        try:
            return bool(tts_mod.speak(t))
        except Exception as exc:
            print(f"aipc-voice-stream: TTS error: {exc}", file=sys.stderr)
            return False

    tts_q = stream_mod.TtsChunkQueue(
        speak=_speak,
        on_chunk=lambda c: _ux("speaking", c[:80], force=True),
    )
    tts_q.start()

    try:
        _mark("llm_request")
        events_iter = (
            stream_events
            if stream_events is not None
            else stream_mod.iter_chat_stream_events(
                text, session_id=session_id, url=CHAT_STREAM_URL
            )
        )
        for ev in events_iter:
            kind = ev.get("event")
            if kind == "token":
                piece = str(ev.get("text") or "")
                if not piece:
                    continue
                _mark("llm_first_token")
                full_parts.append(piece)
                buffer += piece
                # 0014 #5: no per-token overlay ticker — visible text follows
                # the per-sentence TTS callback so display tracks speech.
                chunks, buffer = stream_mod.feed_sentence_chunks(buffer)
                for ch in chunks:
                    _mark("tts_request")
                    tts_q.enqueue(ch)
            elif kind == "error":
                error_msg = str(ev.get("message") or "upstream_error")
                tts_q.cancel()
                return False, error_msg
            elif kind == "done":
                saw_done = True
                final = str(ev.get("text") or "").strip()
                if final and not full_parts:
                    _mark("llm_first_token")  # non-streamed reply arrived whole
                    full_parts.append(final)
                    buffer = final
                chunks, buffer = stream_mod.feed_sentence_chunks(
                    buffer, flush=True
                )
                for ch in chunks:
                    _mark("tts_request")
                    tts_q.enqueue(ch)
            elif kind == "session_id":
                continue
        tts_q.close()
        tts_q.join(timeout=float(os.environ.get("AIPC_STREAM_TTS_JOIN", "180")))
    except Exception as exc:  # noqa: BLE001
        tts_q.cancel()
        return False, str(exc)

    if tts_q.cancelled:
        return False, "cancelled"
    full = "".join(full_parts).strip() or (error_msg)
    if not saw_done and not full:
        return False, "stream ended without done"
    if tts_q.error_count and not tts_q.played_count:
        return False, "tts_all_chunks_failed"
    # Publish total playback length for the wake follow-up window (0014 #4):
    # per-chunk speak() records only the last sentence's length, which would
    # shrink the follow-up window to one sentence. Real-TTS turns only.
    if speak is None and tts_mod is not None and first_play_t and tts_q.played_count:
        try:
            tts_mod.record_last_tts_seconds(time.monotonic() - first_play_t[0])
        except Exception:
            pass
    return True, full


def main(argv=None) -> int:
    args = build_parser().parse_args(argv)
    if args.self_test:
        return _self_test()

    wav_path = args.wav
    if not args.text and not wav_path:
        print("aipc-voice-stream: need --wav or --text", file=sys.stderr)
        return 2
    if wav_path and not Path(wav_path).is_file():
        print(f"aipc-voice-stream: --wav not found: {wav_path}", file=sys.stderr)
        return 1

    _ux("thinking", "stream", force=True)

    # Stream turn latency (voice-telemetry). capture_end ≈ now: wake already
    # finished capture and handed off --wav/--text. Recorded only on a real
    # streamed turn; a stream_fallback lets aipc-voice-once record its own
    # batch turn instead. Best-effort — never affects the turn.
    timer = None
    if aipc_voice_timing is not None:
        try:
            timer = aipc_voice_timing.TurnTimer(path="stream")
            timer.mark("capture_end")
        except Exception:
            timer = None

    text = (args.text or "").strip()
    if not text:
        try:
            text = stt_wav(wav_path)
        except Exception as exc:
            print(f"aipc-voice-stream: STT failed: {exc}", file=sys.stderr)
            if args.no_fallback:
                _ux("error", "stt", force=True)
                return 1
            return fallback_once(wav_path, None, args.session_id)

    print(f"aipc-voice-stream: transcript={text[:120]!r}", flush=True)
    if not _usable(text):
        reply = "没听清楚，请再说一次。"
        if tts_mod is not None:
            try:
                tts_mod.speak(reply)
            except Exception:
                pass
        _ux("done", reply, force=True)
        return 0

    local = _local_intent(text)
    if local is not None:
        if local and tts_mod is not None:
            try:
                tts_mod.speak(local)
            except Exception:
                pass
        _ux("done", (local or "")[:80], force=True)
        return 0

    ok, detail = run_stream_turn(text=text, session_id=args.session_id, timer=timer)
    if ok:
        if timer is not None:
            try:
                timer.flush()
            except Exception:
                pass
        print(f"aipc-voice-stream: ok reply={detail[:120]!r}", flush=True)
        # 0014 #4: end batch-style — done (hold) → followup via a detached
        # child, instead of _ux("done") + exit which let the answer vanish.
        stream_mod.finish_turn_ux(detail)
        return 0

    print(f"aipc-voice-stream: fail {detail}", file=sys.stderr, flush=True)
    if args.no_fallback:
        _ux("error", detail[:80], force=True)
        return 1
    return fallback_once(wav_path, text, args.session_id)


def _self_test() -> int:
    assert CHAT_STREAM_URL.endswith("/chat/stream") or "4100" in CHAT_STREAM_URL
    assert STT_URL.startswith("http://")
    assert stream_mod is not None, "aipc_voice_stream import failed"
    assert stream_mod.self_test() == 0

    # Mocked end-to-end without network/TTS hardware
    events = [
        {"event": "session_id", "session_id": "t", "task_id": "1"},
        {"event": "token", "text": "你好。"},
        {"event": "token", "text": "世界。"},
        {"event": "done", "text": "你好。世界。", "task_id": "1"},
    ]
    spoken: list[str] = []

    ok, full = run_stream_turn(
        text="hi",
        session_id="voice-selftest",
        speak=lambda t: spoken.append(t) or True,
        stream_events=iter(events),
    )
    assert ok, full
    assert "你好" in full
    assert spoken, "expected TTS chunks"
    assert build_parser().parse_args(["--self-test"]).self_test is True

    # Timing marks populate for a streamed turn (llm_ttft / tts_ttfa non-null).
    if aipc_voice_timing is not None:
        tt = aipc_voice_timing.TurnTimer(path="stream")
        tt.mark("capture_end")
        ok2, _ = run_stream_turn(
            text="hi",
            session_id="voice-selftest",
            speak=lambda t: True,
            stream_events=iter(list(events)),
            timer=tt,
        )
        assert ok2
        rec = tt.record(ts=None)
        assert rec["path"] == "stream"
        assert rec["llm_ttft_ms"] is not None
        assert rec["tts_ttfa_ms"] is not None
        assert rec["perceived_ms"] is not None

    # 0014 #4: batch-style ending — done carries a hold, followup child follows
    with tempfile.TemporaryDirectory() as td:
        old_xdg = os.environ.get("XDG_RUNTIME_DIR")
        os.environ["XDG_RUNTIME_DIR"] = td
        try:
            spawned: list[list[str]] = []
            ts = stream_mod.finish_turn_ux("测试答案", spawn=spawned.append)
            state_p = Path(td) / "aipc-voice-state.json"
            st = json.loads(state_p.read_text(encoding="utf-8"))
            assert st["state"] == "done" and float(st["ttl_s"]) >= 12.0
            assert spawned, "followup child not spawned"
            # wake's trailing listening write must not cancel the follow-up
            assert stream_mod._followup_should_write(st, ts)
            assert stream_mod._followup_should_write(
                {"state": "listening", "ts": ts + 5}, ts
            )
            assert not stream_mod._followup_should_write(
                {"state": "thinking", "ts": ts + 5}, ts
            )
            assert stream_mod._followup_main([str(state_p), f"{ts:.6f}", "0", "30"]) == 0
            st2 = json.loads(state_p.read_text(encoding="utf-8"))
            assert st2["state"] == "followup" and float(st2["ttl_s"]) > 0
        finally:
            if old_xdg is None:
                os.environ.pop("XDG_RUNTIME_DIR", None)
            else:
                os.environ["XDG_RUNTIME_DIR"] = old_xdg

    # farewell reply: short hold, no followup child spawned
    with tempfile.TemporaryDirectory() as td:
        old_xdg = os.environ.get("XDG_RUNTIME_DIR")
        os.environ["XDG_RUNTIME_DIR"] = td
        try:
            spawned2: list[list[str]] = []
            stream_mod.finish_turn_ux(
                "好的，那我就先休息了。如果您需要我，随时可以叫我。", spawn=spawned2.append
            )
            state_p = Path(td) / "aipc-voice-state.json"
            st = json.loads(state_p.read_text(encoding="utf-8"))
            assert st["state"] == "done"
            assert float(st["ttl_s"]) < 12.0, "farewell should not get the long hold"
            assert not spawned2, "farewell must not spawn a followup child"
        finally:
            if old_xdg is None:
                os.environ.pop("XDG_RUNTIME_DIR", None)
            else:
                os.environ["XDG_RUNTIME_DIR"] = old_xdg

    print("aipc-voice-stream: self-test OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
