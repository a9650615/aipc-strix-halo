#!/bin/sh
# Runs every 60s (platform-profile-idle-check.timer). Only acts while on AC
# power: after 5 consecutive idle checks (~5 min) with low CPU load and low
# GPU busy%, drops the EC platform_profile to quiet to cut idle power/fan
# noise; any single non-idle check snaps straight back to performance so
# bursty work (e.g. games, compiles) is never throttled by this.
#
# Exception, direct user spec 2026-07-04: LLM inference (llm-ollama's
# llama-server) is a sustained GPU-bound load, not a bursty interactive
# one -- chasing max clocks for it just makes the machine hotter for no
# perceptible latency win, so it gets "balanced" instead of "performance"
# and never counts as idle while it's running.
#
# Second exception, same day: this hardware's package power alone can hit
# 60W+ under load, easily exceeding a smaller/travel USB-C PD charger
# (confirmed in use: <=65W) or a power bank -- the battery then has to
# supplement the shortfall, so it visibly drains even though AC is
# connected and "online". Charger wattage isn't reliably readable from
# sysfs on this platform (ucsi_acpi doesn't expose PDO details here), so
# rather than guess a number, this watches the one signal that's true
# regardless of which charger is plugged in: BAT0 actually reporting
# "Discharging" while AC0 is online means whatever profile is active right
# now draws more than this charger can supply. That instantly forces
# "quiet" (the lowest tier, to actually guarantee the drain stops) ahead of
# every other rule below, including the LLM-inference exception -- a weak
# enough charger can't be assumed to handle "balanced" either.
#
# Instant AC-plug/unplug/resume reactions are handled separately by
# platform-profile-auto (this script never touches battery-mode behaviour).
set -eu

PROFILE_PATH=/sys/firmware/acpi/platform_profile
AC_ONLINE_PATH=/sys/class/power_supply/AC0/online
BAT_STATUS_PATH=/sys/class/power_supply/BAT0/status
GPU_BUSY_PATH=/sys/class/drm/card1/device/gpu_busy_percent
COUNT_FILE=/run/aipc/platform-profile-idle-count
IDLE_CHECKS_REQUIRED=5
LOAD1_IDLE_THRESHOLD=100 # load1 * 100, i.e. 1.00
GPU_BUSY_IDLE_THRESHOLD=10

[ -w "$PROFILE_PATH" ] || exit 0
[ -r "$AC_ONLINE_PATH" ] || exit 0
[ "$(cat "$AC_ONLINE_PATH")" = "1" ] || exit 0

mkdir -p /run/aipc

if [ -r "$BAT_STATUS_PATH" ] && [ "$(cat "$BAT_STATUS_PATH")" = "Discharging" ]; then
	echo 0 > "$COUNT_FILE"
	echo quiet > "$PROFILE_PATH"
	exit 0
fi

if pgrep -x llama-server > /dev/null 2>&1; then
	echo 0 > "$COUNT_FILE"
	echo balanced > "$PROFILE_PATH"
	exit 0
fi

count=0
[ -r "$COUNT_FILE" ] && count=$(cat "$COUNT_FILE")

load1=$(awk '{ printf "%d", $1 * 100 }' /proc/loadavg)
gpu_busy=0
[ -r "$GPU_BUSY_PATH" ] && gpu_busy=$(cat "$GPU_BUSY_PATH")

if [ "$load1" -lt "$LOAD1_IDLE_THRESHOLD" ] && [ "$gpu_busy" -lt "$GPU_BUSY_IDLE_THRESHOLD" ]; then
	count=$((count + 1))
	[ "$count" -gt "$IDLE_CHECKS_REQUIRED" ] && count=$IDLE_CHECKS_REQUIRED
	if [ "$count" -ge "$IDLE_CHECKS_REQUIRED" ]; then
		echo quiet > "$PROFILE_PATH"
	fi
else
	count=0
	echo performance > "$PROFILE_PATH"
fi

echo "$count" > "$COUNT_FILE"
